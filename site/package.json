{
  "name": "@palamedes/site",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "node ./scripts/prebuild-content.mjs",
    "dev": "node ./scripts/prebuild-content.mjs && react-router dev --port 4100",
