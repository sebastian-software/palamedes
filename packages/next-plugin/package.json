{
  "name": "@palamedes/next-plugin",
  "version": "0.1.0",
  "description": "Next.js integration for Lingui using OXC-based macro transformer",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "keywords": [
    "next.js",
    "nextjs",
    "i18n",
    "linguijs",
    "oxc",
    "internationalization",
    "localization",
    "translation"
  ],
  "scripts": {
    "build": "unbuild",
    "stub": "unbuild --stub"
  },
  "homepage": "https://github.com/sebastian-software/palamedes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastian-software/palamedes.git",
    "directory": "packages/next-plugin"
  },
  "bugs": "https://github.com/sebastian-software/palamedes/issues",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist/",
    "palamedes-loader.cjs",
    "palamedes-po-loader.cjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./palamedes-loader": "./palamedes-loader.cjs",
    "./palamedes-po-loader": "./palamedes-po-loader.cjs"
  },
  "dependencies": {
    "@lingui/cli": "^5.9.2",
    "@lingui/conf": "^5.9.2",
    "@palamedes/runtime": "workspace:^",
    "@palamedes/transform": "workspace:^"
  },
  "peerDependencies": {
    "next": "^13 || ^14 || ^15"
  },
  "devDependencies": {
    "next": "^16.1.6",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1"
  }
}
