{
  "name": "@palamedes/core-node",
  "version": "0.1.0",
  "description": "Thin Node.js wrapper around the Palamedes Rust core",
  "keywords": [
    "palamedes",
    "rust",
    "napi",
    "i18n",
    "lingui"
  ],
  "homepage": "https://github.com/sebastian-software/palamedes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastian-software/palamedes.git",
    "directory": "packages/core-node"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "README.md",
    "dist/",
    "palamedes-node.node"
  ],
  "scripts": {
    "build": "node ./scripts/build-native.mjs && unbuild",
    "stub": "unbuild --stub"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "unbuild": "^3.6.1"
  }
}
