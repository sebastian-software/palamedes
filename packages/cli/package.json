{
  "name": "@palamedes/cli",
  "version": "1.2.0",
  "description": "Palamedes CLI for fast message extraction workflows",
  "keywords": [
    "i18n",
    "internationalization",
    "cli",
    "palamedes"
  ],
  "homepage": "https://github.com/sebastian-software/palamedes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastian-software/palamedes.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/sebastian-software/palamedes/issues",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pmds": "./bin/pmds"
  },
  "files": [
    "LICENSE",
    "README.md",
    "bin/",
    "scripts/"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "postinstall": "node ./scripts/install.mjs",
    "test": "node ./scripts/smoke.mjs"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "optionalDependencies": {
    "@palamedes/cli-darwin-arm64": "workspace:^",
    "@palamedes/cli-linux-arm64-gnu": "workspace:^",
    "@palamedes/cli-linux-x64-gnu": "workspace:^",
    "@palamedes/cli-linux-x64-musl": "workspace:^",
    "@palamedes/cli-win32-x64-msvc": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "typescript": "^6.0.3"
  }
}
