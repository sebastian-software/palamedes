{
  "name": "@palamedes/cli",
  "version": "0.6.0",
  "description": "Palamedes CLI for fast message extraction workflows",
  "keywords": [
    "i18n",
    "internationalization",
    "cli",
    "palamedes"
  ],
  "homepage": "https://github.com/sebastian-software/palamedes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastian-software/palamedes.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/sebastian-software/palamedes/issues",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pmds": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "dist/"
  ],
  "scripts": {
    "build": "unbuild",
    "prepack": "pnpm run build",
    "test": "vitest run --globals src/commands/*.test.ts",
    "stub": "unbuild --stub"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@palamedes/config": "workspace:^",
    "@palamedes/core-node": "workspace:^",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "glob": "^13.0.6"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vitest": "^4.1.6"
  }
}
