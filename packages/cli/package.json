{
  "name": "@palamedes/cli",
  "version": "1.4.0",
  "description": "Palamedes CLI for extraction, audits, reports, catalog workflows, and explicit command plugins",
  "keywords": [
    "i18n",
    "internationalization",
    "cli",
    "palamedes"
  ],
  "homepage": "https://github.com/sebastian-software/palamedes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastian-software/palamedes.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/sebastian-software/palamedes/issues",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pmds": "./bin/pmds"
  },
  "files": [
    "LICENSE",
    "README.md",
    "bin/pmds",
    "scripts/",
    "fixtures/",
    "plugin-api.mjs",
    "plugin-api.d.ts"
  ],
  "exports": {
    "./plugin": {
      "types": "./plugin-api.d.ts",
      "import": "./plugin-api.mjs"
    }
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "postinstall": "node ./scripts/install.mjs",
    "test": "node --test ./scripts/plugin-host.test.mjs && node ./scripts/smoke.mjs"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@palamedes/config": "workspace:^",
    "import-meta-resolve": "^4.2.0"
  },
  "optionalDependencies": {
    "@palamedes/cli-darwin-arm64": "workspace:^",
    "@palamedes/cli-linux-arm64-gnu": "workspace:^",
    "@palamedes/cli-linux-x64-gnu": "workspace:^",
    "@palamedes/cli-linux-x64-musl": "workspace:^",
    "@palamedes/cli-win32-x64-msvc": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "typescript": "^6.0.3"
  }
}
