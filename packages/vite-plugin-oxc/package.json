{
  "name": "@palamedes/vite",
  "version": "0.1.0",
  "description": "Vite plugin for Lingui using OXC-based macro transformer",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "keywords": [
    "vite-plugin",
    "i18n",
    "vite",
    "linguijs",
    "oxc",
    "internationalization",
    "localization",
    "translation"
  ],
  "scripts": {
    "build": "unbuild",
    "stub": "unbuild --stub"
  },
  "homepage": "https://github.com/sebastian-software/palamedes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastian-software/palamedes.git",
    "directory": "packages/vite-plugin-oxc"
  },
  "bugs": "https://github.com/sebastian-software/palamedes/issues",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist/"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "dependencies": {
    "@lingui/conf": "^5.9.2",
    "@palamedes/transform": "workspace:^"
  },
  "peerDependencies": {
    "vite": "^3 || ^4 || ^5 || ^6 || ^7"
  },
  "devDependencies": {
    "unbuild": "^3.6.1",
    "vite": "^6.0.2"
  }
}
