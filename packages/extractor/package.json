{
  "name": "@palamedes/extractor",
  "version": "0.11.4",
  "description": "Native message extractor for Palamedes macro syntax",
  "keywords": [
    "palamedes",
    "i18n",
    "extractor",
    "oxc",
    "performance"
  ],
  "homepage": "https://github.com/sebastian-software/palamedes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastian-software/palamedes.git",
    "directory": "packages/extractor"
  },
  "bugs": "https://github.com/sebastian-software/palamedes/issues",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "LICENSE",
    "README.md",
    "dist/"
  ],
  "scripts": {
    "build": "unbuild",
    "test": "vitest run --globals src/extractMessages.test.ts",
    "stub": "unbuild --stub"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@palamedes/core-node": "workspace:^"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vitest": "^4.1.9"
  }
}
