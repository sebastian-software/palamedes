{
  "name": "palamedes",
  "private": true,
  "description": "Next-generation Lingui tooling powered by OXC",
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" build",
    "build:examples": "pnpm -r --filter \"./examples/**\" build",
    "test": "pnpm -r --filter \"./packages/**\" --if-present test",
    "check-types": "pnpm -r --filter \"./packages/**\" exec tsc --noEmit -p tsconfig.json",
    "build:native": "cargo build --workspace",
    "check:rust": "cargo check --workspace",
    "test:rust": "cargo test --workspace"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
